{
    "compileOnSave": false,
    "compilerOptions": {
        "skipLibCheck": true,
        "outDir": "./dist/out-tsc",
        "esModuleInterop": true,
        "sourceMap": true,
        "declaration": false,
        "experimentalDecorators": true,
        "moduleResolution": "bundler",
        "importHelpers": true,
        "target": "ES2022",
        "module": "ES2022",
        "useDefineForClassFields": false,
        "lib": ["ES2022", "dom"],
        "baseUrl": "./src",
        "paths": {
            "app/*":          ["app/*"],
            "helper/*":       ["helper/*"],
            "environments/*": ["environments/*"]
        }
    },
    "angularCompilerOptions": {
        "enableI18nLegacyMessageIdFormat": false
    }
}